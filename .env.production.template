# AlphaArena Production Environment Configuration
# Copy this file to .env.production and fill in your values
# DO NOT commit .env.production to Git!

# ============================================
# 🔐 Supabase Database Configuration
# ============================================
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Service Role Key (for admin operations only)
# WARNING: Never expose this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# 🤖 LLM API Configuration
# ============================================
# Required for LLM Strategy (Issue #19)
# Supports any OpenAI-compatible API

LLM_API_KEY=sk-your-api-key-here
LLM_API_URL=https://api.openai.com/v1

# LLM Model Configuration (Optional)
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# ============================================
# 💰 Cost Control (Optional but Recommended)
# ============================================
# Prevent unexpected API charges

LLM_REQUESTS_PER_MINUTE=60
LLM_DAILY_BUDGET=10

# ============================================
# 🎯 LLM Strategy Trading Configuration
# ============================================

# Minimum confidence threshold (0.0 - 1.0)
# Signals below this confidence will be filtered
LLM_MIN_CONFIDENCE=0.7

# Maximum risk level: low, medium, high
LLM_MAX_RISK_LEVEL=medium

# Cooldown period between signals (milliseconds)
LLM_COOLDOWN_PERIOD=5000

# ============================================
# 🌐 API Server Configuration
# ============================================

# Server port (default: 3001)
PORT=3001

# API base URL for frontend
# Change this to your production API URL
API_BASE_URL=https://your-api.vercel.app

# CORS origins (comma-separated)
CORS_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# ============================================
# 📊 WebSocket Configuration
# ============================================

# WebSocket ping interval (milliseconds)
WS_PING_INTERVAL=30000

# WebSocket ping timeout (milliseconds)
WS_PING_TIMEOUT=5000

# ============================================
# 🎛️ Trading Engine Configuration
# ============================================

# Initial cash for strategies (USDT)
INITIAL_CASH=100000

# Default trading quantity
DEFAULT_QUANTITY=1

# Enable/disable logging
ENABLE_LOGGING=true

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# 📈 Leaderboard Configuration
# ============================================

# Leaderboard auto-refresh interval (seconds)
LEADERBOARD_REFRESH_INTERVAL=60

# Snapshot retention period (days)
LEADERBOARD_SNAPSHOT_RETENTION_DAYS=30

# ============================================
# 🔒 Security Configuration
# ============================================

# Session secret (generate a random string)
SESSION_SECRET=your-super-secret-session-key-change-this

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=100

# ============================================
# 🚀 Deployment Platform Specific
# ============================================

# Vercel-specific (automatically set by Vercel)
# VERCEL=1
# VERCEL_ENV=production

# Railway-specific (automatically set by Railway)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_STATIC_URL=https://your-app.railway.app

# Render-specific (automatically set by Render)
# RENDER=true
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# ============================================
# 🧪 Feature Flags (Optional)
# ============================================

# Enable inter-strategy communication
ENABLE_STRATEGY_COMMUNICATION=false

# Enable strategy persistence to database
ENABLE_STRATEGY_PERSISTENCE=true

# Enable leaderboard snapshots
ENABLE_LEADERBOARD_SNAPSHOTS=true

# Enable price history recording
ENABLE_PRICE_HISTORY=true

# ============================================
# 📝 Notes
# ============================================
#
# 1. Required variables for production:
#    - SUPABASE_URL
#    - SUPABASE_ANON_KEY
#    - LLM_API_KEY (if using LLM strategies)
#    - API_BASE_URL
#
# 2. Security best practices:
#    - Never commit .env.production to Git
#    - Use platform environment variables (Vercel, Railway, Render)
#    - Rotate API keys regularly
#    - Use strong SESSION_SECRET
#
# 3. Cost management:
#    - Set LLM_DAILY_BUDGET to prevent unexpected charges
#    - Monitor token usage via LLM strategy stats
#    - Adjust LLM_REQUESTS_PER_MINUTE based on your API plan
#
# 4. Performance tuning:
#    - Adjust WS_PING_INTERVAL based on your needs
#    - Set appropriate RATE_LIMIT_PER_MINUTE
#    - Configure LOG_LEVEL for production (warn or error)
#
# 5. Platform deployment:
#    - Vercel: Add env vars in Vercel dashboard
#    - Railway: Use `railway variables set KEY=value`
#    - Render: Add env vars in Render dashboard
#
