#!/usr/bin/env node

/**
 * AlphaArena CLI Entry Point
 * 
 * Usage:
 *   alpha-arena backtest [options]
 *   alpha-arena run [options]
 *   alpha-arena stats
 *   alpha-arena help
 */

const { run } = require('../dist/cli/runner');

// Get command line arguments (skip node and script path)
const args = process.argv.slice(2);

// Run CLI
run(args);
