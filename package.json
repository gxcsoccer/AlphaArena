{
  "name": "alphaarena",
  "version": "1.0.0",
  "description": "AlphaArena - Algorithmic Trading Platform",
  "main": "dist/index.js",
  "bin": {
    "alpha-arena": "./bin/alpha-arena"
  },
  "scripts": {
    "postinstall": "patch-package",
    "build": "tsc && vite build && npm run generate:openapi && npm run generate:sitemap",
    "build:client": "vite build",
    "dev": "vite",
    "dev:server": "npm run build && node dist/index.js",
    "start": "node dist/server-start.js",
    "start:legacy": "node dist/index.js",
    "generate:openapi": "ts-node --transpile-only scripts/generate-openapi.ts",
    "generate:sitemap": "ts-node --transpile-only scripts/generate-sitemap.ts",
    "test": "node --max-old-space-size=4096 ./node_modules/.bin/jest",
    "test:coverage": "node --max-old-space-size=4096 ./node_modules/.bin/jest --coverage",
    "test:watch": "node --max-old-space-size=4096 ./node_modules/.bin/jest --watch",
    "test:ci": "node --max-old-space-size=2048 ./node_modules/.bin/jest --ci --maxWorkers=2 --workerIdleMemoryLimit=512MB",
    "cli": "node bin/alpha-arena",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/trading-pair-switching.test.ts && E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/page-navigation.test.ts",
    "test:e2e:trading": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/trading-pair-switching.test.ts",
    "test:e2e:nav": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/page-navigation.test.ts",
    "preview": "vite preview --port 3000 --host",
    "test:e2e:orders": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/order-submission.test.ts",
    "test:e2e:orderbook": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/orderbook-interaction.test.ts",
    "test:e2e:holdings": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/holdings-display.test.ts",
    "test:e2e:trades": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/trade-history.test.ts",
    "test:e2e:conditional": "E2E_BASE_URL=http://localhost:3000 npx ts-node --transpile-only tests/e2e/conditional-orders.test.ts",
    "test:e2e:all": "npm run test:e2e:orders && npm run test:e2e:orderbook && npm run test:e2e:holdings && npm run test:e2e:trades && npm run test:e2e:conditional",
    "benchmark": "ts-node --transpile-only scripts/benchmark/run.ts",
    "benchmark:backtest": "ts-node --transpile-only scripts/benchmark/run.ts --backtest",
    "benchmark:api": "ts-node --transpile-only scripts/benchmark/run.ts --api",
    "benchmark:realtime": "ts-node --transpile-only scripts/benchmark/run.ts --realtime",
    "benchmark:update": "ts-node --transpile-only scripts/benchmark/run.ts --update-baselines",
    "health-check": "E2E_BASE_URL=${E2E_BASE_URL:-http://localhost:3000} ts-node --transpile-only scripts/health-check.ts",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:desktop": "lhci collect --settings.preset=desktop",
    "lighthouse:mobile": "lhci collect --settings.preset=mobile",
    "perf:analyze": "vite-bundle-visualizer",
    "perf:budget": "node scripts/check-performance-budget.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gxcsoccer/AlphaArena.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gxcsoccer/AlphaArena/issues"
  },
  "homepage": "https://github.com/gxcsoccer/AlphaArena#readme",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.39.0",
    "@testing-library/dom": "^8.20.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^13.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/pdfmake": "^0.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/yamljs": "^0.2.34",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "terser": "^5.46.0",
    "ts-jest": "^29.4.6",
    "ts-jest-mock-import-meta": "^1.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.11",
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^2.99.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react-window": "^1.8.8",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "dompurify": "^3.3.3",
    "driver.js": "^1.4.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.3",
    "lightweight-charts": "^5.1.0",
    "marked": "^17.0.4",
    "pdfmake": "^0.3.6",
    "puppeteer": "^24.39.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-window": "^2.2.7",
    "recharts": "^2.12.0",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui": "^5.32.1",
    "swagger-ui-express": "^5.0.1",
    "swagger-ui-react": "^5.32.1",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "ws": "^8.19.0",
    "yamljs": "^0.3.0"
  }
}
