  "bugs": {
    "url": "https://github.com/gxcsoccer/AlphaArena/issues"
  },
  "homepage": "https://github.com/gxcsoccer/AlphaArena#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
