    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
