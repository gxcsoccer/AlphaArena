# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase Anon/Public Key (starts with eyJ...)
SUPABASE_ANON_KEY=

# Optional: Supabase Service Role Key (for admin operations)
# Do not use this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# 🌐 API & WebSocket Configuration
# ============================================

# API Base URL (used for REST API and WebSocket)
# Development: http://localhost:3001
# Production: Your deployed API URL (e.g., https://api.yourapp.com)
VITE_API_URL=http://localhost:3001

# Optional: Dedicated WebSocket URL (if different from API)
# If not set, will auto-convert VITE_API_URL (http→ws, https→wss)
# VITE_WS_URL=ws://localhost:3001
