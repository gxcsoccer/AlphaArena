# ============================================
# 🔷 Supabase Configuration
# ============================================
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

# Supabase project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase Anon/Public Key (starts with eyJ...)
VITE_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for Edge Functions)
# DO NOT use this in client-side code!
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# 🌐 Legacy API & WebSocket Configuration
# ============================================
# These are no longer needed when using Supabase
# Kept for backward compatibility during migration

# API Base URL (deprecated - use Supabase instead)
# VITE_API_URL=http://localhost:3001

# WebSocket URL (deprecated - use Supabase Realtime instead)
# VITE_WS_URL=ws://localhost:3001

# ============================================
# 📝 Setup Instructions
# ============================================
# 1. Create a Supabase project at https://supabase.com
# 2. Run migrations from supabase/migrations/ directory
# 3. Enable Realtime for tables: trades, portfolios, strategies, leaderboard_entries
# 4. Deploy Edge Functions:
#    - supabase functions deploy get-stats
#    - supabase functions deploy get-strategies
#    - supabase functions deploy get-trades
#    - supabase functions deploy get-portfolios
#    - supabase functions deploy get-leaderboard
# 5. Copy this file to .env.local and fill in the values
# 6. For Vercel deployment, add these environment variables in Vercel dashboard
