# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase Anon/Public Key (starts with eyJ...)
SUPABASE_ANON_KEY=

# For frontend (Vite) - used for Edge Functions authentication
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Supabase Service Role Key (for admin operations)
# Do not use this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=

# API Configuration
# Supabase Edge Functions URL for production
# Format: https://<project-ref>.supabase.co/functions/v1
VITE_API_URL=https://plnylmnckssnfpwznpwf.supabase.co/functions/v1

# WebSocket Configuration
# Supabase Realtime is now used for real-time updates.
# The realtime URL is automatically derived from SUPABASE_URL.
# No additional WebSocket configuration needed.

# Stripe Configuration (for payment processing)
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# Frontend URL (used for redirect URLs after payment)
FRONTEND_URL=http://localhost:5173
