# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase Anon/Public Key (starts with eyJ...)
SUPABASE_ANON_KEY=

# For frontend (Vite) - used for Edge Functions authentication
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Supabase Service Role Key (for admin operations)
# Do not use this in client-side code!
# SUPABASE_SERVICE_ROLE_KEY=

# API Configuration
# Supabase Edge Functions URL for production
# Format: https://<project-ref>.supabase.co/functions/v1
VITE_API_URL=https://plnylmnckssnfpwznpwf.supabase.co/functions/v1

# WebSocket Configuration
# Note: Supabase does not support WebSocket long connections.
# Options:
# 1. Keep Railway for WebSocket only
# 2. Use Supabase Realtime (requires code changes)
# 3. Use polling instead of WebSocket
VITE_WS_URL=wss://alphaarena-production.up.railway.app

# Alternative: If using Supabase Realtime, set:
# VITE_SUPABASE_REALTIME_URL=wss://plnylmnckssnfpwznpwf.supabase.co/realtime/v1
