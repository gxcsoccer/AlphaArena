# Production Environment Variables for AlphaArena
# 
# ⚠️ IMPORTANT: These values should be configured in Vercel Dashboard!
# 
# Go to: Vercel Dashboard → AlphaArena Project → Settings → Environment Variables
# 
# DO NOT commit actual secrets to this file. This file only documents
# the required environment variables. Real values should be set in:
# - Vercel Dashboard (for production builds)
# - .env.production.local (for local production testing, git-ignored)
#
# See: docs/deployment/DEPLOYMENT_CHECKLIST.md for setup instructions

# API Configuration
VITE_API_URL=https://plnylmnckssnfpwznpwf.supabase.co/functions/v1

# WebSocket Configuration
# Note: WebSocket URL is optional - the app uses Supabase Realtime for real-time features
# The legacy Railway WebSocket service has been decommissioned.
# If needed in the future, configure a new WebSocket endpoint.
# VITE_WS_URL=wss://your-websocket-server.example.com

# Supabase Configuration
VITE_SUPABASE_URL=https://plnylmnckssnfpwznpwf.supabase.co

# Supabase Anon Key (public, safe for frontend)
# This is the anon/public key - NOT the service role key!
# Anon keys are designed for client-side use and are safe to expose.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBsbnlsbW5ja3NzbmZwd3pucHdmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyMTc5MDUsImV4cCI6MjA4ODc5MzkwNX0.BATHv0SbrOJC2MhitL_i-UyOhHRUv4HGycfecd4H4gg
